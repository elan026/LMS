# ─── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
.vite/
coverage/
*.tsbuildinfo

# ─── Environment files (NEVER commit real secrets) ─────────────────────────────
.env
.env.local
.env.*.local
# Allow example templates
!.env.example

# ─── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── OS & editor noise ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Tool caches ───────────────────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
temp/
tmp/
*.tmp

# ─── Backend: Prisma / SQLite artefacts (legacy) ───────────────────────────────
backend/prisma/dev.db
backend/prisma/*.db
backend/prisma/*.db-journal
backend/prisma/migrations/

# ─── Backend: MongoDB local data ───────────────────────────────────────────────
data/db/
mongod.pid

# ─── Test artefacts ────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ─── Package manager lockfiles (keep one, ignore others) ───────────────────────
# Uncomment whichever you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── Sensitive local data ──────────────────────────────────────────────────────
*.xlsx
*.csv
*.sql
*.bak
